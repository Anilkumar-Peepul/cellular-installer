[Unit]
Description=Network Interface Switcher Service

After=network.target quectel-ppp.service
Requires=quectel-ppp.service

[Service]
Type=simple

ExecStart=/home/pi/cellular/venv/bin/python /home/pi/cellular/ntw_switch.py
WorkingDirectory=/home/pi/cellular

Restart=always
RestartSec=10

User=root
Group=root

StandardOutput=journal
StandardError=journal

KillMode=control-group

TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
